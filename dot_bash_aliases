alias ll='ls -l'
alias la='ls -lA'
alias l='ls -CF'

alias aptsearch='sudo PAGER=cat apt search --names-only'

alias sshno='ssh -o StrictHostKeychecking=no'
alias scpno='scp -o StrictHostKeychecking=no'

alias gitpullsync='git --git-dir=$HOME/sync/.git pull --rebase --autostash'
alias gitpullsetup='git --git-dir=$HOME/clones/setup/.git pull --rebase --autostash'

alias pipreq='pip install -r requirements.txt'
alias venvcreate='python3 -m venv venv'
alias .venvcreate='python3 -m venv .venv'
alias venventer='. ./venv/bin/activate'
alias .venventer='. ./.venv/bin/activate'
alias venvreq='venvcreate && venventer && pipreq'
alias .venvreq='.venvcreate && .venventer && pipreq'

alias dockerrmall='docker rm -f $(docker ps -aq)'
alias dockerrmiall='docker rmi $(docker images -aq)'

alias qmkcompile='qmk compile -kb ferris/sweep -km 3x5'
alias qmkflash='qmk flash -kb ferris/sweep -km 3x5'

alias kdbxclip='keepassxc-cli clip ~/secrets/all.kdbx'
alias jpass='kdbxclip "acloud services"'
alias jtotp='jpass --totp'
alias jvpnpass='kdbxclip "acloud vpn"'
alias jvpntotp='jvpnpass --totp'
alias ncmupass='kdbxclip "ispras ncmu"'
alias imailpass='kdbxclip "ispras mail"'

alias kdbxshowuser='keepassxc-cli show -a username ~/secrets/all.kdbx'
alias kdbxshowpass='keepassxc-cli show -sa password ~/secrets/all.kdbx'
alias kdbxshowtotp='keepassxc-cli show --totp ~/secrets/all.kdbx'
alias jvpnshowuser='kdbxshowuser "acloud vpn"'
alias jvpnshowpass='kdbxshowpass "acloud vpn"'
alias jvpnshowtotp='kdbxshowtotp "acloud vpn"'
alias ivpnshowuser='kdbxshowuser "ispras services"'
alias ivpnshowpass='kdbxshowpass "ispras services"'

alias jenable='
_p=""; read -s -p "[acloud vpn] password for $(whoami): " _p; echo;
echo -e "$(echo $_p | jvpnshowuser -q)\n$(echo $_p | jvpnshowpass -q)\n$(echo $_p | jvpnshowtotp -q)" | \
sudo openvpn3 session-start --config ~/secrets/acloud.ovpn
'
alias jdisable='sudo openvpn3 session-manage --config ~/secrets/acloud.ovpn --disconnect'

alias ienable='
_p=""; read -s -p "[ispras vpn] password for $(whoami): " _p; echo;
echo -e "$(echo $_p | ivpnshowuser -q)\n$(echo $_p | ivpnshowpass -q)" | \
sudo openvpn3 session-start --config ~/secrets/aviator.ovpn
'
alias idisable='sudo openvpn3 session-manage --config ~/secrets/aviator.ovpn --disconnect'

alias penable='sudo awg-quick up ~/secrets/amnezia/wg0.conf'
alias pdisable='sudo awg-quick down ~/secrets/amnezia/wg0.conf'

alias michmandown='michman_dummy_dev down --remove-orphans'
alias michmandownmock='michman_dummy down --remove-orphans'
alias michmandownkeycloak='michman_keycloak_dev down --remove-orphans'
alias michmandownkeystone='michman_keystone_dev down --remove-orphans'

alias michmanlaunch='michmandown && michman_dummy_dev build && michman_dummy_dev up -d --wait && michman_dummy_dev logs -f preload orchestrator provider'
alias michmanlaunchmock='michmandownmock && michman_dummy build && michman_dummy up -d --wait && michman_dummy logs -f preload && michman_dummy logs -f orchestrator provider'
alias michmanlaunchkeycloak='michmandownkeycloak && michman_keycloak_dev build && michman_keycloak_dev up -d --wait && michman_keycloak_dev logs -f preload && michman_keycloak_dev logs -f orchestrator provider'
alias michmanlaunchkeystone='michmandownkeystone && michman_keystone_dev build && michman_keystone_dev up -d --wait && michman_keystone_dev logs -f preload && michman_keystone_dev logs -f orchestrator provider'
alias michmanlaunchtest='michman_dummy down --remove-orphans && michman_dummy build && michman_dummy up --abort-on-container-failure'

alias pucciniparse="puccini-tosca parse -x substitution_mappings.requirements.permissive,imports.implicit.disable"
